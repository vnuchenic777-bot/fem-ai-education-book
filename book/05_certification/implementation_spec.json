{
  "branch": "[ДПО ИИ] 10 — Сертификат или удостоверение",
  "book_title": "Проектирование цифровой образовательной экосистемы факультета: методология, архитектура и реализация курса ДПО по ИИ-инструментам",
  "course_title": "ИИ-инструменты в преподавательской, научной и повседневной работе: от понимания принципов до практического применения",
  "version": "v0.1-jupyter-book",
  "purpose": "Подготовить модель документа об обучении и техническое задание для реализации этапа сертификатов/удостоверений в образовательной платформе.",
  "legal_boundary": "Документ описывает техническую и методическую модель. Юридический статус, порядок выдачи, подписи, регистрации, хранения и учета должен быть согласован с образовательной организацией и ответственными специалистами института.",
  "deliverables": [
    "certificate_model.md",
    "certificate_data_model.ipynb",
    "certificate_lifecycle.ipynb",
    "qr_verification_flow.ipynb",
    "implementation_spec.yaml",
    "implementation_spec.json",
    "data/certificate_entities.yaml",
    "data/certificate_api_contracts.json",
    "data/competencies.yaml",
    "data/example_certificate_payload.json",
    "toc_fragment.yml"
  ],
  "document_types": [
    "certificate",
    "qualification_certificate",
    "completion_statement"
  ],
  "recommended_first_document_type": "certificate",
  "registration_number": {
    "proposed_pattern": "FEM-DPO-AI-{YYYY}-{NNNN}",
    "example": "FEM-DPO-AI-2026-0001",
    "requires_approval": true,
    "uniqueness_scope": "organization + year + program direction",
    "notes": "Формат является проектным и должен быть утвержден образовательной организацией."
  },
  "models": {
    "CertificateTemplate": {
      "description": "Шаблон сертификата или удостоверения. Определяет тип документа, версию макета, статус и структуру отображения.",
      "fields": [
        {
          "name": "id",
          "type": "uuid",
          "required": true,
          "public": false
        },
        {
          "name": "organizationId",
          "type": "uuid",
          "required": true,
          "public": false
        },
        {
          "name": "title",
          "type": "string",
          "required": true,
          "public": false
        },
        {
          "name": "documentType",
          "type": "enum: certificate | qualification_certificate | completion_statement",
          "required": true,
          "public": false
        },
        {
          "name": "templateVersion",
          "type": "string",
          "required": true,
          "public": false
        },
        {
          "name": "layoutDefinition",
          "type": "json",
          "required": true,
          "public": false
        },
        {
          "name": "status",
          "type": "enum: draft | active | archived",
          "required": true,
          "public": false
        },
        {
          "name": "createdAt",
          "type": "datetime",
          "required": true,
          "public": false
        },
        {
          "name": "updatedAt",
          "type": "datetime",
          "required": true,
          "public": false
        }
      ],
      "relationships": [
        {
          "target": "Organization",
          "type": "belongs_to"
        },
        {
          "target": "IssuedCertificate",
          "type": "has_many"
        }
      ]
    },
    "IssuedCertificate": {
      "description": "Выданный документ об обучении. Хранит регистрационный номер, компетенции, ссылку на файл, код проверки и статус.",
      "fields": [
        {
          "name": "id",
          "type": "uuid",
          "required": true,
          "public": false
        },
        {
          "name": "certificateTemplateId",
          "type": "uuid",
          "required": true,
          "public": false
        },
        {
          "name": "organizationId",
          "type": "uuid",
          "required": true,
          "public": false
        },
        {
          "name": "userId",
          "type": "uuid",
          "required": true,
          "public": false
        },
        {
          "name": "courseRunId",
          "type": "uuid",
          "required": true,
          "public": false
        },
        {
          "name": "enrollmentId",
          "type": "uuid",
          "required": true,
          "public": false
        },
        {
          "name": "documentType",
          "type": "enum: certificate | qualification_certificate | completion_statement",
          "required": true,
          "public": false
        },
        {
          "name": "registrationNumber",
          "type": "string",
          "required": true,
          "public": true
        },
        {
          "name": "issuedAt",
          "type": "datetime",
          "required": false,
          "public": true
        },
        {
          "name": "hours",
          "type": "integer",
          "required": true,
          "public": true
        },
        {
          "name": "competencies",
          "type": "json",
          "required": true,
          "public": true
        },
        {
          "name": "status",
          "type": "enum: draft | partial | issued | revoked | reissued",
          "required": true,
          "public": true
        },
        {
          "name": "storageObjectId",
          "type": "uuid",
          "required": false,
          "public": false
        },
        {
          "name": "fileHash",
          "type": "string",
          "required": false,
          "public": false
        },
        {
          "name": "signedByUserId",
          "type": "uuid",
          "required": false,
          "public": false
        },
        {
          "name": "signatureMetadata",
          "type": "json",
          "required": false,
          "public": false
        },
        {
          "name": "verificationCode",
          "type": "string",
          "required": true,
          "public": false
        },
        {
          "name": "verificationUrl",
          "type": "string",
          "required": true,
          "public": true
        }
      ],
      "relationships": [
        {
          "target": "CertificateTemplate",
          "type": "belongs_to"
        },
        {
          "target": "Organization",
          "type": "belongs_to"
        },
        {
          "target": "User",
          "type": "belongs_to"
        },
        {
          "target": "CourseRun",
          "type": "belongs_to"
        },
        {
          "target": "Enrollment",
          "type": "belongs_to"
        },
        {
          "target": "StorageObject",
          "type": "references"
        },
        {
          "target": "AuditLog",
          "type": "creates_events"
        }
      ]
    },
    "StorageObject": {
      "description": "Запись о PDF-файле документа. Сам PDF хранится в файловом хранилище, а не в таблице сертификатов.",
      "fields": [
        {
          "name": "id",
          "type": "uuid",
          "required": true,
          "public": false
        },
        {
          "name": "organizationId",
          "type": "uuid",
          "required": true,
          "public": false
        },
        {
          "name": "bucket",
          "type": "string",
          "required": true,
          "public": false
        },
        {
          "name": "storageKey",
          "type": "string",
          "required": true,
          "public": false
        },
        {
          "name": "originalFileName",
          "type": "string",
          "required": true,
          "public": false
        },
        {
          "name": "mimeType",
          "type": "string",
          "required": true,
          "public": false
        },
        {
          "name": "sizeBytes",
          "type": "integer",
          "required": true,
          "public": false
        },
        {
          "name": "checksum",
          "type": "string",
          "required": true,
          "public": false
        },
        {
          "name": "visibility",
          "type": "enum: private | organization | public",
          "required": true,
          "public": false
        },
        {
          "name": "createdByUserId",
          "type": "uuid",
          "required": true,
          "public": false
        },
        {
          "name": "createdAt",
          "type": "datetime",
          "required": true,
          "public": false
        }
      ],
      "relationships": [
        {
          "target": "IssuedCertificate",
          "type": "referenced_by"
        }
      ]
    },
    "AuditLog": {
      "description": "Журнал критических действий: генерация, выдача, отзыв, повторная выдача и проверка документа.",
      "fields": [
        {
          "name": "id",
          "type": "uuid",
          "required": true,
          "public": false
        },
        {
          "name": "organizationId",
          "type": "uuid",
          "required": true,
          "public": false
        },
        {
          "name": "actorUserId",
          "type": "uuid",
          "required": false,
          "public": false
        },
        {
          "name": "action",
          "type": "string",
          "required": true,
          "public": false
        },
        {
          "name": "targetType",
          "type": "string",
          "required": true,
          "public": false
        },
        {
          "name": "targetId",
          "type": "uuid",
          "required": true,
          "public": false
        },
        {
          "name": "metadata",
          "type": "json",
          "required": false,
          "public": false
        },
        {
          "name": "createdAt",
          "type": "datetime",
          "required": true,
          "public": false
        }
      ],
      "relationships": [
        {
          "target": "IssuedCertificate",
          "type": "tracks"
        }
      ]
    }
  },
  "statuses": {
    "CertificateTemplate": [
      "draft",
      "active",
      "archived"
    ],
    "IssuedCertificate": [
      "draft",
      "partial",
      "issued",
      "revoked",
      "reissued"
    ],
    "Enrollment": [
      "invited",
      "active",
      "completed",
      "failed",
      "withdrawn"
    ]
  },
  "generation_algorithm": [
    {
      "step": 1,
      "name": "Проверка прав инициатора",
      "details": "Проверить роль, организацию, CourseRun и разрешение на генерацию документов."
    },
    {
      "step": 2,
      "name": "Проверка завершения курса",
      "details": "Enrollment должен иметь итоговый статус completed; все обязательные элементы курса должны быть приняты."
    },
    {
      "step": 3,
      "name": "Проверка компетенций",
      "details": "Для ПК-ИИ-1 — ПК-ИИ-10 должны быть приняты артефакт и тест/практическая проверка."
    },
    {
      "step": 4,
      "name": "Выбор шаблона",
      "details": "Используется активный CertificateTemplate соответствующей организации и типа документа."
    },
    {
      "step": 5,
      "name": "Генерация регистрационного номера",
      "details": "Номер генерируется по утвержденному шаблону и проверяется на уникальность."
    },
    {
      "step": 6,
      "name": "Генерация verificationCode",
      "details": "Код должен быть криптографически устойчивым и не должен совпадать с регистрационным номером."
    },
    {
      "step": 7,
      "name": "Формирование PDF",
      "details": "PDF строится на основе шаблона и данных IssuedCertificate."
    },
    {
      "step": 8,
      "name": "Сохранение PDF",
      "details": "PDF сохраняется как StorageObject; в IssuedCertificate пишется storageObjectId и fileHash."
    },
    {
      "step": 9,
      "name": "Фиксация подписи",
      "details": "Если подпись утверждена, сохранить signedByUserId и signatureMetadata."
    },
    {
      "step": 10,
      "name": "Запись AuditLog",
      "details": "Фиксируется событие certificate.issued или certificate.generated."
    },
    {
      "step": 11,
      "name": "Уведомление слушателя",
      "details": "Система создает уведомление или письмо о готовности документа."
    }
  ],
  "permissions": [
    "certificate.template.create",
    "certificate.template.update",
    "certificate.issue",
    "certificate.revoke",
    "certificate.reissue",
    "certificate.read.own",
    "certificate.read.organization",
    "certificate.verify.public"
  ],
  "roles": {
    "super_admin": [
      "all certificate permissions"
    ],
    "organization_admin": [
      "certificate.template.create",
      "certificate.template.update",
      "certificate.issue",
      "certificate.revoke",
      "certificate.reissue",
      "certificate.read.organization"
    ],
    "program_admin": [
      "certificate.issue",
      "certificate.read.organization"
    ],
    "teacher": [
      "certificate.read.organization",
      "certificate.issue when assigned and allowed"
    ],
    "reviewer": [
      "certificate.read.organization when assigned"
    ],
    "student": [
      "certificate.read.own"
    ],
    "public": [
      "certificate.verify.public"
    ]
  },
  "audit_events": [
    "certificate.template.created",
    "certificate.template.updated",
    "certificate.template.activated",
    "certificate.generated",
    "certificate.issued",
    "certificate.revoked",
    "certificate.reissued",
    "certificate.downloaded",
    "certificate.verified.public",
    "certificate.verification.failed"
  ],
  "api": {
    "base_prefix": "/api/v1",
    "endpoints": [
      {
        "method": "GET",
        "path": "/certificates/me",
        "access": "authenticated learner",
        "description": "Возвращает список документов текущего пользователя.",
        "response_fields": [
          "id",
          "registrationNumber",
          "courseTitle",
          "hours",
          "issuedAt",
          "status",
          "verificationUrl"
        ]
      },
      {
        "method": "GET",
        "path": "/certificates/{id}",
        "access": "owner or authorized admin/teacher",
        "description": "Возвращает карточку документа с учетом прав доступа.",
        "response_fields": [
          "id",
          "documentType",
          "registrationNumber",
          "holder",
          "course",
          "competencies",
          "status",
          "issuedAt",
          "downloadUrl"
        ]
      },
      {
        "method": "POST",
        "path": "/course-runs/{id}/certificates/generate",
        "access": "organization_admin | program_admin | authorized teacher/reviewer",
        "description": "Создает документы для слушателей, выполнивших условия завершения курса.",
        "request_fields": [
          "mode",
          "enrollmentIds",
          "templateId",
          "dryRun"
        ],
        "response_fields": [
          "generated",
          "skipped",
          "errors"
        ]
      },
      {
        "method": "GET",
        "path": "/certificates/verify/{verificationCode}",
        "access": "public rate-limited",
        "description": "Публичная проверка подлинности по коду или QR-ссылке.",
        "response_fields": [
          "valid",
          "status",
          "holderName",
          "courseTitle",
          "hours",
          "issuedAt",
          "issuer",
          "registrationNumber"
        ]
      },
      {
        "method": "POST",
        "path": "/certificates/{id}/revoke",
        "access": "organization_admin | super_admin",
        "description": "Отзывает документ и фиксирует причину в AuditLog.",
        "request_fields": [
          "reason",
          "comment"
        ],
        "response_fields": [
          "id",
          "status",
          "revokedAt"
        ]
      },
      {
        "method": "POST",
        "path": "/certificates/{id}/reissue",
        "access": "organization_admin | super_admin",
        "description": "Создает новую версию документа при исправлении ошибки или повторной выдаче.",
        "request_fields": [
          "reason",
          "changes"
        ],
        "response_fields": [
          "oldCertificateId",
          "newCertificateId",
          "newRegistrationNumber"
        ]
      }
    ],
    "public_verification_response_example": {
      "valid": true,
      "status": "issued",
      "holderName": "Иван Иванов",
      "courseTitle": "ИИ-инструменты в преподавательской, научной и повседневной работе: от понимания принципов до практического применения",
      "hours": 72,
      "issuedAt": "2026-12-20T00:00:00.000Z",
      "issuer": "ФЭМ СПБГТИ(ТУ)",
      "registrationNumber": "FEM-DPO-AI-2026-0001"
    },
    "non_public_fields": [
      "userId",
      "email",
      "phone",
      "storageKey",
      "fileHash",
      "signatureMetadata",
      "internalAuditMetadata",
      "ipAddress",
      "userAgent"
    ]
  },
  "validation_rules": [
    "Не выдавать документ, если курс не завершен.",
    "Не выдавать документ, если не подтверждены все обязательные компетенции.",
    "Не выдавать документ без активного шаблона.",
    "Не публиковать внутренние идентификаторы и служебные поля на публичной странице проверки.",
    "Не хранить PDF в таблице сертификатов: только StorageObject и метаданные.",
    "Не разрешать отзыв или повторную выдачу без причины и AuditLog.",
    "Не утверждать юридический статус документа на уровне кода или интерфейса без локального решения образовательной организации."
  ],
  "acceptance_criteria": [
    "Администратор может создать активный шаблон документа.",
    "Система может сгенерировать документ для слушателя, завершившего курс.",
    "Регистрационный номер уникален в заданной области.",
    "verificationCode отличается от регистрационного номера и является устойчивым к перебору.",
    "QR-ссылка ведет на публичную страницу проверки.",
    "Публичная проверка не раскрывает лишние персональные данные.",
    "PDF хранится через StorageObject.",
    "Действия выдачи, отзыва и повторной выдачи фиксируются в AuditLog.",
    "Отозванный документ отображается как недействительный.",
    "В README и главе указано, что юридический порядок требует согласования с институтом."
  ],
  "open_questions": [
    "Какой точный тип документа выбирается для первого потока: сертификат или удостоверение?",
    "Кто утверждает шаблон документа?",
    "Кто является уполномоченным подписантом?",
    "Какой формат электронной подписи использовать?",
    "Нужна ли электронная печать или отметка организации?",
    "Какой порядок регистрационного номера утверждает институт?",
    "Нужен ли журнал учета документов в отдельной форме?",
    "Сколько лет хранить PDF и метаданные?",
    "Нужна ли публичная проверка без авторизации?",
    "Какие персональные данные допустимо показывать на публичной странице?",
    "Как оформляется частичное освоение и донабор компетенций?",
    "Какой порядок отзыва и повторной выдачи документа?"
  ]
}